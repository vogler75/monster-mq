# =======================
# AI Agent Types
# =======================

type Agent {
    name: String!
    org: String!
    site: String!
    description: String
    version: String!
    namespace: String!
    nodeId: String!
    enabled: Boolean!
    skills: [AgentSkill!]!
    inputTopics: [String!]!
    outputTopics: [String!]!
    triggerType: String!
    cronExpression: String
    cronIntervalMs: Long
    cronPrompt: String
    provider: String
    providerName: String
    model: String
    endpoint: String
    serviceVersion: String
    systemPrompt: String
    maxTokens: Int
    temperature: Float
    maxToolIterations: Int
    memoryWindowSize: Int
    stateEnabled: Boolean!
    enableThinking: Boolean!
    conversationLogEnabled: Boolean!
    mcpServers: [String!]!
    useMonsterMqMcp: Boolean!
    defaultArchiveGroup: String!
    contextLastvalTopics: JSON
    contextRetainedTopics: [String!]!
    contextHistoryQueries: [ContextHistoryQuery!]!
    timezone: String
    taskTimeoutMs: Long
    subAgentsAllowAll: Boolean!
    subAgents: [String!]!
    createdAt: String!
    updatedAt: String!
}

type AgentSkill {
    name: String!
    description: String!
    inputSchema: JSON
}

# =======================
# AI Agent Input Types
# =======================

input AgentInput {
    name: String!
    org: String
    site: String
    namespace: String!
    nodeId: String!
    description: String
    version: String
    skills: [AgentSkillInput!]
    inputTopics: [String!]
    outputTopics: [String!]
    triggerType: String
    cronExpression: String
    cronIntervalMs: Long
    cronPrompt: String
    provider: String
    providerName: String
    model: String
    apiKey: String
    endpoint: String
    serviceVersion: String
    systemPrompt: String
    maxTokens: Int
    temperature: Float
    maxToolIterations: Int
    memoryWindowSize: Int
    stateEnabled: Boolean
    enableThinking: Boolean
    conversationLogEnabled: Boolean
    mcpServers: [String!]
    useMonsterMqMcp: Boolean
    defaultArchiveGroup: String
    contextLastvalTopics: JSON
    contextRetainedTopics: [String!]
    contextHistoryQueries: [ContextHistoryQueryInput!]
    timezone: String
    taskTimeoutMs: Long
    subAgentsAllowAll: Boolean
    subAgents: [String!]
    enabled: Boolean
}

input AgentSkillInput {
    name: String!
    description: String!
    inputSchema: JSON
}

type ContextHistoryQuery {
    archiveGroup: String!
    topics: [String!]!
    lastSeconds: Int!
    interval: String!
    function: String!
    fields: [String!]!
    decimals: Int
}

input ContextHistoryQueryInput {
    archiveGroup: String!
    topics: [String!]!
    lastSeconds: Int!
    interval: String!
    function: String!
    fields: [String!]
    decimals: Int
}

# =======================
# AI Agent Mutations
# =======================

type AgentMutations {
    create(input: AgentInput!): Agent!
    update(name: String!, input: AgentInput!): Agent!
    delete(name: String!): Boolean!
    start(name: String!): Agent!
    stop(name: String!): Agent!
}

# =======================
# AI Agent Queries
# =======================

extend type Query {
    agents(nodeId: String, enabled: Boolean): [Agent!]!
    agent(name: String!): Agent
    configuredProviders: [String!]!
}

extend type Mutation {
    agent: AgentMutations
}
