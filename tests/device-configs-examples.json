  {
    "name": "Bulking",
    "namespace": "default",
    "nodeId": "*",
    "config": {
      "nodes": [
        {
          "id": "node_1761336482614",
          "name": "function_0",
          "type": "function",
          "config": {
            "script": "if (!state.bulk) {\n    state.bulk = [];\n}\n\nlet v = JSON.parse(inputs.input1.value);\nlet ts = new Date(v.TimeMS ?? Date.now());\n\nstate.bulk.push({\n  \"topic\": inputs.input1.topic, \n  \"value\": v.Value ?? null,\n  \"time\": ts.toISOString()\n});\n\n//console.log(\"Topic: \", inputs.input1.topic, \"Length: \", state.bulk.length);\n\nif (state.bulk.length == 100) {\n  outputs.send(\"output1\", JSON.stringify(state.bulk));\n  state.bulk = [];\n}"
          },
          "inputs": [
            "input1"
          ],
          "outputs": [
            "output1"
          ],
          "language": "javascript",
          "position": {
            "x": 221,
            "y": 126
          }
        }
      ],
      "version": "1.0.0",
      "connections": [],
      "description": null
    },
    "enabled": false,
    "type": "Flow-Class",
