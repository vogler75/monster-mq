# Monster-MQ integration test environment configuration.
# Copy this file to .env and adjust the values for your environment.

# --- Broker connection ---
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_USERNAME=Test
MQTT_PASSWORD=Test

# Admin credentials (used by ACL/user management tests)
MQTT_ADMIN_USER=Admin
MQTT_ADMIN_PASS=Admin

# --- GraphQL / REST ---
GRAPHQL_URL=http://localhost:4000/graphql

# --- Skip test groups (set to 1 to disable) ---
SKIP_MQTT3=0
SKIP_MQTT5=0
SKIP_GRAPHQL=0
SKIP_REST=0
SKIP_OPCUA=1
SKIP_DATABASE=1
SKIP_FLOW=0
SKIP_QUEUING=0
SKIP_LATENCY=1
SKIP_I3X=1
